{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/:categorySlug/:citySlug/:businessSlug",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, stale-while-revalidate=86400"
        },
        {
          "key": "Vary",
          "value": "Accept-Encoding"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/seo?page=home&lang=fr"
    },
    {
      "source": "/en",
      "destination": "/api/seo?page=home&lang=en"
    },
    {
      "source": "/blogue/:articleId",
      "destination": "/api/seo?blogSlug=:articleId&lang=fr"
    },
    {
      "source": "/en/blog/:articleId",
      "destination": "/api/seo?blogSlug=:articleId&lang=en"
    },
    {
      "source": "/blogue",
      "destination": "/api/seo?page=blog&lang=fr"
    },
    {
      "source": "/en/blog",
      "destination": "/api/seo?page=blog&lang=en"
    },
    {
      "source": "/a-propos",
      "destination": "/api/seo?page=about&lang=fr"
    },
    {
      "source": "/about",
      "destination": "/api/seo?page=about&lang=en"
    },
    {
      "source": "/en/about",
      "destination": "/api/seo?page=about&lang=en"
    },
    {
      "source": "/faq",
      "destination": "/api/seo?page=faq&lang=fr"
    },
    {
      "source": "/en/faq",
      "destination": "/api/seo?page=faq&lang=en"
    },
    {
      "source": "/politique-de-confidentialite",
      "destination": "/api/seo?page=privacy&lang=fr"
    },
    {
      "source": "/privacy-policy",
      "destination": "/api/seo?page=privacy&lang=en"
    },
    {
      "source": "/en/privacy-policy",
      "destination": "/api/seo?page=privacy&lang=en"
    },
    {
      "source": "/mentions-legales",
      "destination": "/api/seo?page=legal&lang=fr"
    },
    {
      "source": "/legal-notice",
      "destination": "/api/seo?page=legal&lang=en"
    },
    {
      "source": "/en/legal-notice",
      "destination": "/api/seo?page=legal&lang=en"
    },
    {
      "source": "/en/entreprise/:businessSlug",
      "destination": "/api/seo?slug=:businessSlug&categorySlug=entreprise&lang=en"
    },
    {
      "source": "/entreprise/:businessSlug",
      "destination": "/api/seo?slug=:businessSlug&categorySlug=entreprise"
    },
    {
      "source": "/en/entreprise/:citySlug/:businessSlug",
      "destination": "/api/seo?citySlug=:citySlug&slug=:businessSlug&lang=en"
    },
    {
      "source": "/entreprise/:citySlug/:businessSlug",
      "destination": "/api/seo?citySlug=:citySlug&slug=:businessSlug"
    },
    {
      "source": "/en/:categorySlug/:citySlug/:businessSlug",
      "destination": "/api/seo?categorySlug=:categorySlug&citySlug=:citySlug&slug=:businessSlug&lang=en"
    },
    {
      "source": "/:categorySlug/:citySlug/:businessSlug",
      "destination": "/api/seo?categorySlug=:categorySlug&citySlug=:citySlug&slug=:businessSlug"
    },
    {
      "source": "/en/city/:citySlug",
      "destination": "/api/seo?citySlug=:citySlug&lang=en"
    },
    {
      "source": "/ville/:citySlug",
      "destination": "/api/seo?citySlug=:citySlug"
    },
    {
      "source": "/en/region/:regionSlug",
      "destination": "/api/seo?regionSlug=:regionSlug&lang=en"
    },
    {
      "source": "/region/:regionSlug",
      "destination": "/api/seo?regionSlug=:regionSlug"
    },
    {
      "source": "/en/category/:categorySlug/:subCategorySlug",
      "destination": "/api/seo?categorySlug=:categorySlug&subCategorySlug=:subCategorySlug&lang=en"
    },
    {
      "source": "/en/category/:categorySlug",
      "destination": "/api/seo?categorySlug=:categorySlug&lang=en"
    },
    {
      "source": "/categorie/:categorySlug/:subCategorySlug",
      "destination": "/api/seo?categorySlug=:categorySlug&subCategorySlug=:subCategorySlug"
    },
    {
      "source": "/categorie/:categorySlug",
      "destination": "/api/seo?categorySlug=:categorySlug"
    },
    {
      "source": "/((?!api/|sitemaps/|sitemap\\.xml|sitemap-en\\.xml|sitemap-fr\\.xml|blogue/|blog/).*)",
      "destination": "/spa.html"
    }
  ]
}
